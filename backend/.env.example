# LimeSurvey RemoteControl API (enable JSON-RPC under Global Settings > Interfaces)
LIMESURVEY_URL=https://your-limesurvey.com/index.php/admin/remotecontrol
LIMESURVEY_USERNAME=your_username
LIMESURVEY_PASSWORD=your_password

# Optional: filter surveys to a specific LimeSurvey user
# LIMESURVEY_FILTER_USER=

# Backend server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend CORS (comma-separated origins; production: https://et-spirex.onrender.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI report narratives (optional) ──
# Azure OpenAI is pay-as-you-go (new Azure accounts may get trial credits — not permanently free).
# Claude.ai Pro subscription does NOT include API access; use console.anthropic.com for an API key.
# AI_PROVIDER=auto
# AI_PROVIDER=anthropic
# AI_PROVIDER=azure
# AI_PROVIDER=none

# Anthropic Claude (recommended if you have an API key)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Project management spine (optional Postgres) ──
# Create a Render Postgres instance or local DB, then set:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/et_pm

# ── Gmail Workspace (optional) ──
# Create OAuth credentials in Google Cloud Console (Web application).
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback
# GOOGLE_OAUTH_SUCCESS_URL=http://localhost:5173/my-work?gmail=connected
# GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# GOOGLE_AUTH_SUCCESS_URL=http://localhost:5173/
# APP_PUBLIC_URL=http://localhost:5173
# GMAIL_INBOX_QUERY=in:inbox newer_than:14d
# GMAIL_TEAM_EMAIL_MAP=sunil@elastictree.com:Sunil,ambika@elastictree.com:Ambika

# Company owner — always admin with full edit rights (defaults below)
# SUPER_ADMIN_USERNAME=Sunil
# SUPER_ADMIN_EMAIL=sunilmukkath@elastictree.com
# WORKSPACE_DOMAIN=elastictree.com
