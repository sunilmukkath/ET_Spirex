# LimeSurvey RemoteControl API (enable JSON-RPC under Global Settings > Interfaces)
LIMESURVEY_URL=https://your-limesurvey.com/index.php/admin/remotecontrol
LIMESURVEY_USERNAME=your_username
LIMESURVEY_PASSWORD=your_password

# Optional: filter surveys to a specific LimeSurvey user
# LIMESURVEY_FILTER_USER=

# Backend server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
